    "# ─── 4. Декодирование mp4 → JPG кэш ──────────────────────────────────────────\n",
    "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "CACHE = Path('/kaggle/working/v2_cache')\n",
    "CACHE.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "def _decode_one(vpath, out_dir, T, sz, crop_face):\n",
    "    out_dir = Path(out_dir)\n",
    "    if out_dir.exists() and len(list(out_dir.glob('f_*.jpg'))) >= T:\n",
    "        return True\n",
    "    out_dir.mkdir(parents=True, exist_ok=True)\n",
    "    frames = []\n",
    "    try:\n",
    "        with av.open(str(vpath)) as c:\n",
    "            st = c.streams.video[0]\n",
    "            total = st.frames or 0\n",
    "            idx = set() if total<=0 else (set(range(total)) if total<=T\n",
    "                                          else {int(total/T*k) for k in range(T)})\n",
    "            i = done = 0\n",
    "            for pkt in c.demux(st):\n",
    "                for fr in pkt.decode():\n",
    "                    if not idx or i in idx:\n",
    "                        img = fr.to_ndarray(format='rgb24')\n",
    "                        h,w = img.shape[:2]\n",
    "                        if max(h,w)>640:\n",
    "                            k=640/max(h,w); img=cv2.resize(img,(int(w*k),int(h*k)),cv2.INTER_AREA)\n",
    "                        if crop_face: img = _crop_face(img)\n",
    "                        frames.append(cv2.resize(img,(sz,sz),cv2.INTER_LINEAR))\n",
    "                    i += 1\n",
    "                    if len(frames)==T: done=1; break\n",
    "                if done: break\n",
    "    except Exception: return False\n",
    "    if not frames: return False\n",
    "    while len(frames)<T: frames.append(frames[-1].copy())\n",
    "    for k,im in enumerate(frames):\n",
    "        cv2.imwrite(str(out_dir/f'f_{k:03d}.jpg'),\n",
    "                    cv2.cvtColor(im,cv2.COLOR_RGB2BGR),\n",
    "                    [cv2.IMWRITE_JPEG_QUALITY, 92])\n",
    "    return True\n",
    "\n",
    "\n",
    "def precache(records, T, sz, tag, workers=4):\n",
    "    vids = [r for r in records if r.get('source_type')=='video']\n",
    "    if not vids: return records\n",
    "    jobs = []\n",
    "    for r in vids:\n",
    "        dst = CACHE / r['dataset'] / r.get('manipulation','unk') / Path(r['path']).stem\n",
    "        jobs.append((r, dst))\n",
    "    print(f'{tag}: декодирую {len(jobs)} mp4 → JPG...')\n",
    "    ok = 0\n",
    "    with ThreadPoolExecutor(max_workers=workers) as ex:\n",
    "        futures = {ex.submit(_decode_one, r['path'], dst, T, sz,\n",
    "                              r['dataset'] not in ('dfdc_faces',)): (r,dst)\n",
    "                   for r,dst in jobs}\n",
    "        for fut in tqdm(as_completed(futures), total=len(futures), desc=tag):\n",
    "            r, dst = futures[fut]\n",
    "            try: ok_f = fut.result()\n",
    "            except: ok_f = False\n",
    "            if ok_f:\n",
    "                r['path'] = str(dst); r['source_type'] = 'folder'; ok += 1\n",
    "    print(f'{tag}: {ok}/{len(jobs)} ok')\n",
    "    return [r for r in records if r.get('source_type')!='video']\n",
    "\n",
    "\n",
    "T_, sz_ = CFG['target_frames'], CFG['image_size']\n",
    "train_recs = precache(train_recs, T_, sz_, 'train')\n",
    "val_recs   = precache(val_recs,   T_, sz_, 'val')\n",
    "print('Кэш готов ✓')"
   ]
