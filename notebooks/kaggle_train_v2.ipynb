    "print(SEP)\n",
    "\n",
    "for epoch in tqdm(range(start_ep, CFG['epochs']), desc='Epochs', position=0):\n",
    "    gc.collect(); torch.cuda.empty_cache()\n",
    "\n",
    "    if epoch==CFG['freeze_epochs']:\n",
    "        model.unfreeze_backbone()\n",
    "        print(f'  Обучаю {sum(p.numel() for p in model.parameters() if p.requires_grad)/1e6:.1f}M params')\n",
    "\n",
    "    # ── Train ──\n",
    "    model.train()\n",
    "    tr_loss=0.; n=0\n",
    "    opt.zero_grad(set_to_none=True)\n",
    "    pbar=tqdm(train_ld, desc=f'train ep{epoch}', leave=False, dynamic_ncols=True)\n",
    "    t0=time.time()\n",
    "\n",
    "    for step, batch in enumerate(pbar):\n",
    "        v=batch['video'].to(device, non_blocking=True)\n",
    "        l=batch['label'].to(device, non_blocking=True)\n",
    "\n",
