    "            with torch.amp.autocast('cuda', enabled=CFG['use_amp']):\n",
    "                logits=model(v)\n",
    "                val_loss+=loss_fn(logits,l).item(); nv+=1\n",
    "            all_p+=torch.sigmoid(logits).cpu().tolist()\n",
    "            all_l+=l.cpu().int().tolist()\n",
    "\n",
    "    gc.collect(); torch.cuda.empty_cache(); _malloc_trim()\n",
    "\n",
    "    vm=compute_metrics(all_l,all_p)\n",
    "    vm['loss']=val_loss/max(nv,1)\n",
    "    dt=time.time()-t0\n",
    "    lr_h=opt.param_groups[1]['lr']\n",
    "\n",
    "    row=dict(epoch=epoch, train_loss=round(tr_loss/max(n,1),4),\n",
    "             val_loss=round(vm['loss'],4), auroc=round(vm['auroc'],4),\n",
    "             f1=round(vm['f1'],4), eer=round(vm['eer'],4),\n",
    "             lr=round(lr_h,6), time_s=round(dt,1))\n",
    "    history.append(row)\n",
    "\n",
