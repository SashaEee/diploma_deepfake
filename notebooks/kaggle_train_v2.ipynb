    "# ─── 9. Инициализация ─────────────────────────────────────────────────────────\n",
    "train_ds=TrainDS(train_frames, train_labels)\n",
    "val_ds  =ValDS(val_frames, val_labels)\n",
    "\n",
    "train_ld=DataLoader(train_ds, batch_size=CFG['batch'], shuffle=True,\n",
    "                    num_workers=0, pin_memory=False, drop_last=True)\n",
    "val_ld  =DataLoader(val_ds,   batch_size=CFG['batch']*2, shuffle=False,\n",
    "                    num_workers=0, pin_memory=False)\n",
    "\n",
    "model=DeepfakeDetector(CFG).to(device)\n",
    "model.freeze_backbone()\n",
    "\n",
    "bb_ids={id(p) for p in model.spatial.bb.parameters()}\n",
    "other_p=[p for p in model.parameters() if id(p) not in bb_ids]\n",
    "bb_p=list(model.spatial.bb.parameters())\n",
    "\n",
    "opt=AdamW([\n",
    "    {'params': bb_p,    'lr': CFG['lr_backbone']},\n",
    "    {'params': other_p, 'lr': CFG['lr']},\n",
    "], weight_decay=CFG['wd'])\n",
    "\n",
    "# OneCycleLR — warmup + cosine decay, лучше чем CosineAnnealingLR\n",
    "total_steps = CFG['epochs'] * len(train_ld)\n",
    "sched=OneCycleLR(opt, max_lr=[CFG['lr_backbone']*5, CFG['lr']],\n",
    "                 total_steps=total_steps, pct_start=0.1,\n",
    "                 anneal_strategy='cos', div_factor=25, final_div_factor=1e4)\n",
    "scaler=torch.amp.GradScaler(enabled=CFG['use_amp'])\n",
    "\n",
