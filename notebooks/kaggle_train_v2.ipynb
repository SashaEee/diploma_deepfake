    "\n",
    "    # Flush остатков\n",
    "    if n%CFG['grad_accum']!=0:\n",
    "        scaler.unscale_(opt)\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), CFG['clip_grad'])\n",
    "        scaler.step(opt); scaler.update(); opt.zero_grad(set_to_none=True); sched.step()\n",
    "\n",
    "    # ── Val ──\n",
    "    model.eval()\n",
    "    all_p,all_l=[],[]; val_loss=0.; nv=0\n",
