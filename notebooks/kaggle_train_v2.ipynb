    "# ─── 11. CelebDF-v2 eval с TTA (flip) ────────────────────────────────────────\n",
    "# TTA: прогоняем каждый сэмпл дважды (оригинал + flip), усредняем вероятности\n",
    "# Даёт +1-2% AUROC бесплатно — стандартный приём в соревнованиях\n",
    "\n",
    "def _load_video_fc(path, T, sz):\n",
    "    \"\"\"Декодирует видео с face crop → (T,3,sz,sz).\"\"\"\n",
    "    frames=[]\n",
    "    try:\n",
    "        with av.open(str(path)) as c:\n",
    "            st=c.streams.video[0]; total=st.frames or 0\n",
    "            idx=(set() if total<=0 else (set(range(total)) if total<=T\n",
    "                 else {int(total/T*k) for k in range(T)}))\n",
    "            i=done=0\n",
    "            for pkt in c.demux(st):\n",
    "                for fr in pkt.decode():\n",
    "                    if not idx or i in idx:\n",
    "                        img=fr.to_ndarray(format='rgb24')\n",
    "                        h,w=img.shape[:2]\n",
    "                        if max(h,w)>640:\n",
    "                            k=640/max(h,w); img=cv2.resize(img,(int(w*k),int(h*k)),cv2.INTER_AREA)\n",
    "                        img=_crop_face(img)\n",
    "                        frames.append(cv2.resize(img,(sz,sz),cv2.INTER_LINEAR))\n",
    "                    i+=1\n",
    "                    if len(frames)==T: done=1; break\n",
    "                if done: break\n",
    "    except Exception: pass\n",
    "    while len(frames)<T: frames.append(frames[-1].copy() if frames else np.zeros((sz,sz,3),np.uint8))\n",
    "    arr=torch.from_numpy(np.stack(frames[:T])).float().permute(0,3,1,2).div_(255.).sub_(MEAN).div_(STD)\n",
    "    return arr\n",
    "\n",
    "class CelebDFDS(Dataset):\n",
    "    def __init__(self, records, T, sz): self.recs=records; self.T=T; self.sz=sz\n",
    "    def __len__(self): return len(self.recs)\n",
    "    def __getitem__(self,idx):\n",
    "        r=self.recs[idx]\n",
    "        vid=_load_video_fc(r['path'],self.T,self.sz)\n",
    "        return {'video':vid,'label':float(r['label'])}\n",
    "\n",
    "\n",
    "def eval_with_tta(model, records, dev, T, sz, tag='eval'):\n",
    "    \"\"\"Оценка с TTA (оригинал + горизонтальный flip).\"\"\"\n",
    "    model.eval()\n",
    "    ds=CelebDFDS(records,T,sz)\n",
    "    ld=DataLoader(ds,batch_size=CFG['batch']*2,num_workers=0,pin_memory=False)\n",
    "\n",
    "    all_p1,all_p2,all_l=[],[],[]\n",
    "    with torch.no_grad():\n",
    "        for batch in tqdm(ld, desc=tag, dynamic_ncols=True):\n",
    "            v=batch['video'].to(dev); l=batch['label']\n",
    "            with torch.amp.autocast('cuda', enabled=CFG['use_amp']):\n",
    "                p1=torch.sigmoid(model(v)).cpu().tolist()\n",
    "                p2=torch.sigmoid(model(v.flip(-1))).cpu().tolist()  # horizontal flip\n",
    "            all_p1+=p1; all_p2+=p2\n",
    "            all_l+=l.int().tolist()\n",
    "\n",
    "    # Среднее оригинала и flip\n",
    "    probs=[(p1+p2)/2 for p1,p2 in zip(all_p1,all_p2)]\n",
    "    m=compute_metrics(all_l,probs)\n",
    "\n",
    "    # Также без TTA для сравнения\n",
    "    m_no_tta=compute_metrics(all_l,all_p1)\n",
    "    print(f'{tag} без TTA:   AUROC={m_no_tta[\"auroc\"]:.4f} | F1={m_no_tta[\"f1\"]:.4f}')\n",
    "    print(f'{tag} с TTA:     AUROC={m[\"auroc\"]:.4f} | F1={m[\"f1\"]:.4f} | EER={m[\"eer\"]:.4f}')\n",
    "    return m\n",
    "\n",
    "\n",
    "# Загружаем лучшую модель\n",
    "ckpt=torch.load(out/'best_model_v2.pt', map_location=device)\n",
    "model.load_state_dict(ckpt['state_dict'])\n",
    "print(f'Загружена best_model_v2.pt (ep {ckpt[\"epoch\"]})')\n",
    "\n",
    "# DFDC val (без TTA — уже в RAM)\n",
    "model.eval(); all_p,all_l=[],[]\n",
    "with torch.no_grad():\n",
    "    for batch in tqdm(val_ld, desc='DFDC final'):\n",
    "        v=batch['video'].to(device)\n",
    "        all_p+=torch.sigmoid(model(v)).cpu().tolist()\n",
    "        all_l+=batch['label'].int().tolist()\n",
    "dfdc_m=compute_metrics(all_l,all_p)\n",
    "print(f'DFDC val: AUROC={dfdc_m[\"auroc\"]:.4f} | F1={dfdc_m[\"f1\"]:.4f} | EER={dfdc_m[\"eer\"]:.4f}')\n",
    "\n",
    "# CelebDF-v2 с TTA\n",
    "if celebdf_recs:\n",
    "    print('\\nCelebDF-v2 eval с TTA...')\n",
    "    celebdf_m=eval_with_tta(model, celebdf_recs, device, T_, sz_, 'CelebDF-v2')\n",
    "else:\n",
    "    celebdf_m={'auroc':None,'f1':None,'eer':None}\n",
    "    print('CelebDF-v2 не загружен')"
