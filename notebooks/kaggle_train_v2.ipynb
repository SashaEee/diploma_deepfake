    "            sched.step()\n",
    "\n",
    "        pbar.set_postfix(loss=f'{loss.item()*CFG[\"grad_accum\"]:.3f}',\n",
    "                          lr=f\"{opt.param_groups[1]['lr']:.1e}\")\n",
