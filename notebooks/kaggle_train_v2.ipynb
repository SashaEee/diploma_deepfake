    "# ─── 5. Загрузка в RAM ────────────────────────────────────────────────────────\n",
    "def _resize_sq(img, sz):\n",
    "    h,w = img.shape[:2]\n",
    "    if max(h,w)>640: k=640/max(h,w); img=cv2.resize(img,(int(w*k),int(h*k)),cv2.INTER_AREA)\n",
    "    return cv2.resize(img,(sz,sz),cv2.INTER_LINEAR)\n",
    "\n",
    "def _load_u8(rec, T, sz):\n",
    "    src = rec.get('source_type')\n",
    "    files = []\n",
    "    if src=='files': files = list(rec['files'])\n",
    "    elif src=='folder':\n",
    "        p = Path(rec['path'])\n",
    "        for ext in IMG_EXTS: files.extend(p.glob(f'*{ext}'))\n",
    "        files = sorted(files)\n",
    "    if not files: return None\n",
    "    n = len(files)\n",
    "    idx_list = list(range(n)) if n<=T else [int(n/T*k) for k in range(T)]\n",
    "    frames = []\n",
    "    for i in idx_list:\n",
    "        img = cv2.imread(str(files[i]), cv2.IMREAD_COLOR)\n",
    "        if img is None: continue\n",
    "        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "        frames.append(_resize_sq(img, sz))\n",
    "    while len(frames)<T: frames.append(frames[-1].copy() if frames else np.zeros((sz,sz,3),np.uint8))\n",
    "    return np.stack(frames[:T]).astype(np.uint8)\n",
    "\n",
    "\n",
    "def load_to_ram(records, T, sz, tag):\n",
    "    n = len(records)\n",
    "    frames = np.zeros((n,T,sz,sz,3), dtype=np.uint8)\n",
    "    labels = np.zeros(n, dtype=np.int64)\n",
    "    ok = 0\n",
    "    for i, rec in enumerate(tqdm(records, desc=f'RAM {tag}', dynamic_ncols=True)):\n",
    "        arr = _load_u8(rec, T, sz)\n",
    "        if arr is not None: frames[i]=arr; ok+=1\n",
    "        labels[i] = int(rec['label'])\n",
    "    print(f'{tag}: {ok}/{n} ok | {frames.nbytes/1024**3:.2f} GB')\n",
    "    return frames, labels\n",
    "\n",
    "\n",
    "train_frames, train_labels = load_to_ram(train_recs, T_, sz_, 'train')\n",
    "val_frames,   val_labels   = load_to_ram(val_recs,   T_, sz_, 'val')\n",
    "gc.collect()\n",
    "print(f'RAM: train={train_frames.shape}, val={val_frames.shape}')"
   ]
