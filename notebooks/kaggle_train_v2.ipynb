    "# ─── 7. Focal Loss + Label Smoothing ─────────────────────────────────────────\n",
    "# Обычный BCE: одинаково штрафует лёгкие (p=0.99) и тяжёлые примеры (p=0.51)\n",
    "# Focal Loss: (1-p_t)^gamma — сильно снижает вес лёгких примеров\n",
    "# Label Smoothing: label → label*(1-ε) + ε/2 — убирает overconfidence\n",
    "\n",
    "class FocalBCELoss(nn.Module):\n",
    "    def __init__(self, gamma=1.5, smooth=0.1):\n",
    "        super().__init__()\n",
    "        self.gamma = gamma\n",
    "        self.smooth = smooth\n",
    "\n",
    "    def forward(self, logits, labels):\n",
    "        # Label smoothing: 0 → 0.05, 1 → 0.95 (при smooth=0.1)\n",
    "        ls = labels * (1 - self.smooth) + 0.5 * self.smooth\n",
    "        # BCE per sample\n",
    "        bce = F.binary_cross_entropy_with_logits(logits, ls, reduction='none')\n",
    "        # Focal weight — weight = (1 - p_t)^gamma\n",
    "        # p_t: вероятность правильного класса\n",
    "        p = torch.sigmoid(logits)\n",
    "        p_t = p * labels + (1 - p) * (1 - labels)\n",
    "        focal_w = (1 - p_t.detach()) ** self.gamma\n",
    "        return (focal_w * bce).mean()\n",
    "\n",
    "\n",
    "loss_fn = FocalBCELoss(gamma=CFG['focal_gamma'], smooth=CFG['label_smooth'])\n",
    "\n",
    "def compute_metrics(labels, probs):\n",
    "    lb=np.array(labels); pb=np.array(probs)\n",
    "    if len(set(lb))<2: return {'auroc':0.,'f1':0.,'eer':0.}\n",
    "    auroc=float(roc_auc_score(lb,pb))\n",
    "    f1=float(f1_score(lb,(pb>=0.5).astype(int),zero_division=0))\n",
    "    fpr,tpr,_=roc_curve(lb,pb); fnr=1-tpr\n",
    "    eer=float((fpr+fnr)[np.argmin(np.abs(fnr-fpr))]/2)\n",
    "    return {'auroc':auroc,'f1':f1,'eer':eer}\n",
    "\n",
    "print(f'FocalBCELoss: gamma={CFG[\"focal_gamma\"]}, label_smooth={CFG[\"label_smooth\"]} ✓')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 8. Dataset с MixUp + Random Erasing ─────────────────────────────────────\n",
    "MEAN = torch.tensor([0.485,0.456,0.406]).view(1,3,1,1)\n",
    "STD  = torch.tensor([0.229,0.224,0.225]).view(1,3,1,1)\n",
    "\n",
    "def _aug_frame(img):\n",
    "    \"\"\"Аугментация одного кадра uint8 HWC.\"\"\"\n",
    "    if random.random()<0.3:\n",
    "        img=cv2.GaussianBlur(img,(random.choice([3,5]),random.choice([3,5])),0)\n",
    "    if random.random()<0.35:\n",
    "        q=random.randint(25,80)\n",
    "        _,enc=cv2.imencode('.jpg',img,[cv2.IMWRITE_JPEG_QUALITY,q])\n",
    "        img=cv2.imdecode(enc,cv2.IMREAD_COLOR)\n",
    "    if random.random()<0.5:\n",
    "        a=random.uniform(0.75,1.25); b=random.uniform(-20,20)\n",
    "        img=np.clip(img.astype(np.float32)*a+b,0,255).astype(np.uint8)\n",
    "    return img\n",
    "\n",
    "def _random_erase(vid, prob=0.25):\n",
    "    \"\"\"Скрывает случайный патч во всех кадрах (отключает позиционные shortcuts).\"\"\"\n",
    "    if random.random()>=prob: return vid\n",
    "    _,_,H,W = vid.shape\n",
    "    rh=random.uniform(0.05,0.25); rw=random.uniform(0.05,0.25)\n",
    "    ch,cw = int(H*rh), int(W*rw)\n",
    "    y=random.randint(0,H-ch); x=random.randint(0,W-cw)\n",
    "    vid=vid.clone(); vid[:,:,y:y+ch,x:x+cw]=0\n",
    "    return vid\n",
    "\n",
    "class TrainDS(Dataset):\n",
    "    def __init__(self, frames, labels):\n",
    "        self.frames=frames; self.labels=labels\n",
    "    def __len__(self): return len(self.labels)\n",
    "    def __getitem__(self,idx):\n",
    "        frames=self.frames[idx].copy()\n",
    "        for i in range(len(frames)): frames[i]=_aug_frame(frames[i])\n",
    "        vid=torch.from_numpy(frames).float().permute(0,3,1,2).div_(255.).sub_(MEAN).div_(STD)\n",
    "        if random.random()<0.5: vid=vid.flip(-1)\n",
    "        vid=_random_erase(vid, CFG['erase_prob'])\n",
    "        return {'video':vid, 'label':float(self.labels[idx])}\n",
    "\n",
    "class ValDS(Dataset):\n",
    "    def __init__(self, frames, labels):\n",
    "        self.frames=frames; self.labels=labels\n",
    "    def __len__(self): return len(self.labels)\n",
    "    def __getitem__(self,idx):\n",
    "        vid=torch.from_numpy(self.frames[idx]).float().permute(0,3,1,2).div_(255.).sub_(MEAN).div_(STD)\n",
    "        return {'video':vid, 'label':float(self.labels[idx])}\n",
    "\n",
    "\n",
    "def mixup_batch(v, l, alpha=0.2):\n",
    "    \"\"\"MixUp: смешивает пары сэмплов, модель учится на непрерывных метках.\"\"\"\n",
    "    if alpha<=0: return v, l, l, 1.0\n",
    "    lam=np.random.beta(alpha,alpha)\n",
    "    idx=torch.randperm(v.shape[0], device=v.device)\n",
    "    return lam*v+(1-lam)*v[idx], l, l[idx], lam\n",
    "\n",
    "\n",
    "print('Dataset + MixUp + Random Erasing ✓')"
   ]
  },
