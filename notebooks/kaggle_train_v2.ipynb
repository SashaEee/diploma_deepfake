    "            loss = lam*loss_fn(logits,la) + (1-lam)*loss_fn(logits,lb)\n",
    "            loss = loss / CFG['grad_accum']\n",
    "\n",
    "        scaler.scale(loss).backward()\n",
    "        tr_loss += loss.item()*CFG['grad_accum']; n+=1\n",
    "\n",
    "        if (step+1)%CFG['grad_accum']==0:\n",
