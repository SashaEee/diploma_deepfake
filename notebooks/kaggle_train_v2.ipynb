    "# ─── 2. Детекция лица (Haar cascade) ─────────────────────────────────────────\n",
    "IMG_EXTS = ('.png','.jpg','.jpeg','.PNG','.JPG','.JPEG')\n",
    "_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')\n",
    "\n",
    "def _crop_face(img_rgb, margin=0.3):\n",
    "    \"\"\"Обрезать лицо с margin. Fallback: центральный кроп 65%.\"\"\"\n",
    "    gray  = cv2.cvtColor(img_rgb, cv2.COLOR_RGB2GRAY)\n",
    "    faces = _cascade.detectMultiScale(gray, 1.1, 4, minSize=(40,40))\n",
    "    h, w  = img_rgb.shape[:2]\n",
    "    if len(faces) > 0:\n",
    "        areas = [fw*fh for (fx,fy,fw,fh) in faces]\n",
    "        fx,fy,fw,fh = faces[int(np.argmax(areas))]\n",
    "        mx,my = int(fw*margin), int(fh*margin)\n",
    "        x1,y1 = max(0,fx-mx), max(0,fy-my)\n",
    "        x2,y2 = min(w,fx+fw+mx), min(h,fy+fh+my)\n",
    "        crop = img_rgb[y1:y2, x1:x2]\n",
    "        if crop.shape[0]>10 and crop.shape[1]>10:\n",
    "            return crop\n",
    "    cr = 0.65\n",
    "    ch,cw = int(h*cr), int(w*cr)\n",
    "    return img_rgb[(h-ch)//2:(h+ch)//2, (w-cw)//2:(w+cw)//2]\n",
    "\n",
    "def _is_frame_dir(p):\n",
    "    if not p.is_dir(): return False\n",
    "    return any(next(p.glob(f'*{e}'), None) for e in IMG_EXTS)\n",
    "\n",
    "def _walk_frame_dirs(root, max_depth=6):\n",
    "    out = []\n",
    "    stack = [(Path(root), 0)]\n",
    "    while stack:\n",
    "        p, d = stack.pop()\n",
    "        if d > max_depth: continue\n",
    "        try: children = list(p.iterdir())\n",
    "        except: continue\n",
    "        if _is_frame_dir(p): out.append(p); continue\n",
    "        for c in children:\n",
    "            if c.is_dir(): stack.append((c, d+1))\n",
    "    return out\n",
    "\n",
    "print('Face detector ready ✓ (Haar cascade)')"
   ]
