    "# ─── 3. Манифесты датасетов ────────────────────────────────────────────────────\n",
    "# Каждая запись: {'path': str, 'label': 0|1, 'dataset': str,\n",
    "#                  'source_type': 'video'|'folder'|'files'}\n",
    "\n",
    "def _make_rec(path, label, dataset, manip, src_type, files=None):\n",
    "    r = {'path': str(path), 'label': label, 'dataset': dataset,\n",
    "         'manipulation': manip, 'source_type': src_type}\n",
    "    if files: r['files'] = files\n",
    "    return r\n",
    "\n",
    "# ── FF++ C23 (xdxd003/ff-c23) ──────────────────────────────────────────────────\n",
    "# Структура A: original_sequences/ + manipulated_sequences/<Method>/c23/videos/*.mp4\n",
    "# Структура B: real/ + fake/ (папки с frame-img или mp4)\n",
    "# Структура C: рекурсивный поиск\n",
    "def build_ff_c23(root, max_per_class=1000):\n",
    "    root = Path(root)\n",
    "    if not root.exists(): print(f'FF++ C23 не найден: {root}'); return []\n",
    "    print(f'FF++ C23: {root}')\n",
    "    reals, fakes = [], []\n",
    "\n",
    "    # Структура A: standard FF++ tree\n",
    "    orig = root / 'original_sequences'\n",
    "    mani = root / 'manipulated_sequences'\n",
    "    if orig.exists():\n",
    "        for cand in [orig/'youtube'/'c23'/'videos', orig/'youtube'/'raw'/'videos', orig/'actors'/'c23'/'videos']:\n",
    "            if cand.exists():\n",
    "                for vp in sorted(cand.glob('*.mp4')):\n",
    "                    reals.append(_make_rec(vp, 0, 'ff_c23', 'orig', 'video'))\n",
    "                print(f'  real: {len(reals)} mp4 из {cand.name}')\n",
    "                break\n",
    "    if mani.exists():\n",
    "        methods = ['Deepfakes','Face2Face','FaceSwap','NeuralTextures','FaceShifter']\n",
    "        for m in methods:\n",
    "            for cand in [mani/m/'c23'/'videos', mani/m/'raw'/'videos']:\n",
    "                if cand.exists():\n",
    "                    for vp in sorted(cand.glob('*.mp4')):\n",
    "                        fakes.append(_make_rec(vp, 1, 'ff_c23', m, 'video'))\n",
    "                    print(f'  fake/{m}: {sum(1 for f in fakes if f[\"manipulation\"]==m)} mp4')\n",
    "                    break\n",
    "\n",
    "    # Структура B: flat real/fake dirs\n",
    "    if not reals and not fakes:\n",
    "        for sub, lbl, tag in [('real',0,'orig'),('original',0,'orig'),\n",
    "                               ('fake',1,'ff_fake'),('manipulated',1,'ff_fake')]:\n",
    "            d = root / sub\n",
    "            if not d.exists(): continue\n",
    "            for vp in sorted(d.rglob('*.mp4')):\n",
    "                rec = _make_rec(vp, lbl, 'ff_c23', tag, 'video')\n",
    "                (reals if lbl==0 else fakes).append(rec)\n",
    "            dirs = _walk_frame_dirs(d)\n",
    "            for vd in dirs:\n",
    "                rec = _make_rec(vd, lbl, 'ff_c23', tag, 'folder')\n",
    "                (reals if lbl==0 else fakes).append(rec)\n",
    "        print(f'  fallback: real={len(reals)}, fake={len(fakes)}')\n",
    "\n",
    "    # Структура C: рекурсивный поиск\n",
    "    if not reals and not fakes:\n",
    "        print('  рекурсивный поиск...')\n",
    "        for vd in _walk_frame_dirs(root):\n",
    "            path_str = str(vd).lower()\n",
    "            lbl = 0 if any(k in path_str for k in ['original','real','youtube']) else 1\n",
    "            (reals if lbl==0 else fakes).append(_make_rec(vd, lbl, 'ff_c23', 'auto', 'folder'))\n",
    "        for vp in sorted(root.rglob('*.mp4')):\n",
    "            path_str = str(vp).lower()\n",
    "            lbl = 0 if any(k in path_str for k in ['original','real','youtube']) else 1\n",
    "            (reals if lbl==0 else fakes).append(_make_rec(vp, lbl, 'ff_c23', 'auto', 'video'))\n",
    "\n",
    "    random.shuffle(reals); random.shuffle(fakes)\n",
    "    reals = reals[:max_per_class]; fakes = fakes[:max_per_class]\n",
    "    print(f'FF++ C23 ИТОГО: real={len(reals)}, fake={len(fakes)}')\n",
    "    return reals + fakes\n",
    "\n",
    "\n",
    "# ── DFD — Google DeepFake Detection (sanikatiwarekar) ─────────────────────────\n",
    "# Структура: FaceForensics++/DeepFakeDetection/\n",
    "#   original_sequences/actors/c23/videos/*.mp4   — real\n",
    "#   manipulated_sequences/DeepFakeDetection/c23/videos/*.mp4 — fake\n",
    "def build_dfd(root, max_per_class=800):\n",
    "    root = Path(root)\n",
    "    if not root.exists(): print(f'DFD не найден: {root}'); return []\n",
    "    print(f'DFD: {root}')\n",
    "    reals, fakes = [], []\n",
    "\n",
    "    # Стандартная структура DFD\n",
    "    real_cands = [\n",
    "        root / 'original_sequences' / 'actors' / 'c23' / 'videos',\n",
    "        root / 'original_sequences' / 'actors' / 'raw' / 'videos',\n",
    "        root / 'FaceForensics++' / 'original_sequences' / 'actors' / 'c23' / 'videos',\n",
    "    ]\n",
    "    fake_cands = [\n",
    "        root / 'manipulated_sequences' / 'DeepFakeDetection' / 'c23' / 'videos',\n",
    "        root / 'manipulated_sequences' / 'DeepFakeDetection' / 'raw' / 'videos',\n",
    "        root / 'FaceForensics++' / 'manipulated_sequences' / 'DeepFakeDetection' / 'c23' / 'videos',\n",
    "    ]\n",
    "    for cand in real_cands:\n",
    "        if cand.exists():\n",
    "            for vp in sorted(cand.glob('*.mp4')):\n",
    "                reals.append(_make_rec(vp, 0, 'dfd', 'orig', 'video'))\n",
    "            print(f'  real: {len(reals)} mp4'); break\n",
    "    for cand in fake_cands:\n",
    "        if cand.exists():\n",
    "            for vp in sorted(cand.glob('*.mp4')):\n",
    "                fakes.append(_make_rec(vp, 1, 'dfd', 'dfd_fake', 'video'))\n",
    "            print(f'  fake: {len(fakes)} mp4'); break\n",
    "\n",
    "    # Fallback: поиск по всему датасету\n",
    "    if not reals and not fakes:\n",
    "        print('  fallback: поиск...')\n",
    "        for vp in sorted(root.rglob('*.mp4')):\n",
    "            ps = str(vp).lower()\n",
    "            lbl = 0 if 'actor' in ps or 'original' in ps else 1\n",
    "            (reals if lbl==0 else fakes).append(_make_rec(vp, lbl, 'dfd', 'auto', 'video'))\n",
    "        # Папки с кадрами\n",
    "        for vd in _walk_frame_dirs(root):\n",
    "            ps = str(vd).lower()\n",
    "            lbl = 0 if 'actor' in ps or 'original' in ps else 1\n",
    "            (reals if lbl==0 else fakes).append(_make_rec(vd, lbl, 'dfd', 'auto', 'folder'))\n",
    "\n",
    "    random.shuffle(reals); random.shuffle(fakes)\n",
    "    reals = reals[:max_per_class]; fakes = fakes[:max_per_class]\n",
    "    print(f'DFD ИТОГО: real={len(reals)}, fake={len(fakes)}')\n",
    "    return reals + fakes\n",
    "\n",
    "\n",
    "# ── DFDC Faces (itamargr) ────────────────────────────────────────────────────\n",
    "def build_dfdc_faces(root, max_per_class=1000):\n",
    "    root = Path(root)\n",
    "    if not root.exists(): print(f'DFDC faces не найден: {root}'); return []\n",
    "    print(f'DFDC faces: {root}')\n",
    "    records = []\n",
    "    for split in ['train','validation']:\n",
    "        for sub, lbl in [('real',0),('fake',1)]:\n",
    "            d = root / split / sub\n",
    "            if not d.exists(): continue\n",
    "            subdirs = [p for p in d.iterdir() if p.is_dir() and _is_frame_dir(p)]\n",
    "            if subdirs:\n",
    "                for vd in subdirs:\n",
    "                    records.append(_make_rec(vd, lbl, 'dfdc_faces',\n",
    "                                             'dfdc_fake' if lbl else 'none', 'folder'))\n",
    "                print(f'  {split}/{sub}: {len(subdirs)} папок'); continue\n",
    "            files = sorted(p for p in d.iterdir() if p.suffix.lower() in ('.jpg','.jpeg','.png'))\n",
    "            if not files: continue\n",
    "            groups = {}\n",
    "            for f in files:\n",
    "                m = re.match(r'^(.+?)[_\\-]\\d+$', f.stem)\n",
    "                groups.setdefault(m.group(1) if m else f.stem, []).append(str(f))\n",
    "            n_add = 0\n",
    "            for prefix, fl in groups.items():\n",
    "                if len(fl) < 2: continue\n",
    "                records.append(_make_rec(d, lbl, 'dfdc_faces',\n",
    "                                         'dfdc_fake' if lbl else 'none', 'files',\n",
    "                                         files=sorted(fl)))\n",
    "                n_add += 1\n",
    "            print(f'  {split}/{sub}: {n_add} группы')\n",
    "    real = [r for r in records if r['label']==0]\n",
    "    fake = [r for r in records if r['label']==1]\n",
    "    random.shuffle(real); random.shuffle(fake)\n",
    "    print(f'DFDC faces ИТОГО: real={len(real[:max_per_class])}, fake={len(fake[:max_per_class])}')\n",
    "    return real[:max_per_class] + fake[:max_per_class]\n",
    "\n",
    "\n",
    "# ── DFDC sample (fallback) ────────────────────────────────────────────────────\n",
    "def build_dfdc_sample(root):\n",
    "    root = Path(root)\n",
    "    meta = root / 'metadata.json'\n",
    "    if not meta.exists(): return []\n",
    "    data = json.loads(meta.read_text())\n",
    "    recs = []\n",
    "    for fname, info in data.items():\n",
    "        vp = root / fname\n",
    "        if not vp.exists(): continue\n",
    "        lbl = 1 if info.get('label') == 'FAKE' else 0\n",
    "        recs.append(_make_rec(vp, lbl, 'dfdc_sample', 'dfdc_fake' if lbl else 'none', 'video'))\n",
    "    print(f'DFDC sample: {len(recs)} видео')\n",
    "    return recs\n",
    "\n",
    "\n",
    "# ── CelebDF-v2 ────────────────────────────────────────────────────────────────\n",
    "def build_celebdf(root, max_videos=500):\n",
    "    root = Path(root)\n",
    "    if not root.exists(): print(f'CelebDF-v2 не найден: {root}'); return []\n",
    "    subs = [p for p in root.iterdir() if p.is_dir()]\n",
    "    if subs and not any((root/d).exists() for d in ['Celeb-real','Celeb-synthesis']):\n",
    "        root = subs[0]\n",
    "    recs = []\n",
    "    list_file = root / 'List_of_testing_videos.txt'\n",
    "    if list_file.exists():\n",
    "        for line in list_file.read_text().strip().splitlines():\n",
    "            parts = line.strip().split()\n",
    "            if len(parts) < 2: continue\n",
    "            vp = root / parts[1]\n",
    "            if not vp.exists(): continue\n",
    "            our_lbl = 0 if int(parts[0])==1 else 1\n",
    "            recs.append(_make_rec(vp, our_lbl, 'celebdf', 'celebdf_fake' if our_lbl else 'none', 'video'))\n",
    "    else:\n",
    "        for folder, lbl in [('Celeb-real',0),('YouTube-real',0),('Celeb-synthesis',1)]:\n",
    "            fp = root / folder\n",
    "            if fp.exists():\n",
    "                for vp in sorted(fp.glob('*.mp4')):\n",
    "                    recs.append(_make_rec(vp, lbl, 'celebdf', 'celebdf_fake' if lbl else 'none', 'video'))\n",
    "    real = [r for r in recs if r['label']==0]\n",
    "    fake = [r for r in recs if r['label']==1]\n",
    "    n = min(max_videos//2, len(real), len(fake))\n",
